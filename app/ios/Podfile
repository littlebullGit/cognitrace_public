# CogniTrace iOS — llamadart (llama.cpp) for on-device Gemma 4 inference
platform :ios, '16.4'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.4'
    end
  end

  # CRITICAL: Force linker flags so llamadart native symbols are exported.
  # Without these, llama.cpp symbols get stripped and the engine fails silently.
  require 'xcodeproj'
  project_path = 'Runner.xcodeproj'
  project = Xcodeproj::Project.open(project_path)
  project.targets.each do |target|
    if target.name == 'Runner'
      target.build_configurations.each do |config|
        ld_flags = config.build_settings['OTHER_LDFLAGS']
        ld_flags = ld_flags.nil? ? ['$(inherited)'] :
                   ld_flags.is_a?(String) ? ld_flags.split(' ') : ld_flags
        ld_flags.unshift('$(inherited)') unless ld_flags.include?('$(inherited)')
        ld_flags << '-all_load'           unless ld_flags.include?('-all_load')
        ld_flags << '-Wl,-export_dynamic' unless ld_flags.include?('-Wl,-export_dynamic')
        config.build_settings['OTHER_LDFLAGS'] = ld_flags
        config.build_settings['STRIP_STYLE'] = 'non-global'
      end
    end
  end
  project.save
end
